@model string
@{
    ViewData["Title"] = "Event Expired";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-5 text-center">
        <div class="card p-5">
            <i class="bi bi-calendar-x text-secondary" style="font-size:3.5rem"></i>
            <h4 class="mt-3">Event Expired</h4>
            <p class="text-muted">The event <strong>@Model</strong> has ended. Registration is no longer available.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-gold mt-2">Go to Home</a>
        </div>
    </div>
</div>
