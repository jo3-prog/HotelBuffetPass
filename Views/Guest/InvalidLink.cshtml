@{
    ViewData["Title"] = "Invalid Link";
}
<div class="row justify-content-center mt-5">
    <div class="col-md-5 text-center">
        <div class="card p-5">
            <i class="bi bi-link-45deg text-danger" style="font-size:3.5rem"></i>
            <h4 class="mt-3">Invalid Registration Link</h4>
            <p class="text-muted">This link is not valid or the event has been deactivated.</p>
            <a asp-controller="Home" asp-action="Index" class="btn btn-gold mt-2">Go to Home</a>
        </div>
    </div>
</div>
