@model EventDetailViewModel
@{
    ViewData["Title"] = Model.EventName;
    var isExpired = Model.EndDate < DateTime.Today;
}

<div class="mb-3">
    <a asp-action="Dashboard" class="text-muted text-decoration-none">
        <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
    </a>
</div>

<div class="row g-4">
    <!-- Left: Event Info -->
    <div class="col-lg-4">
        <div class="card mb-3">
            <div class="card-header card-header-gold py-3">
                <h6 class="mb-0"><i class="bi bi-calendar-event me-2"></i>Event Info</h6>
            </div>
            <div class="card-body">
                <h5 class="fw-bold">@Model.EventName</h5>
                <p class="text-muted mb-1"><i class="bi bi-building me-1"></i>@Model.HallName</p>
                <p class="text-muted mb-1">
                    <i class="bi bi-calendar3 me-1"></i>
                    @Model.StartDate.ToString("dd MMM yyyy") – @Model.EndDate.ToString("dd MMM yyyy")
                </p>
                <p class="text-muted mb-2">
                    <i class="bi bi-clock me-1"></i>
                    @Model.BuffetStartTime.ToString(@"hh\:mm") – @Model.BuffetEndTime.ToString(@"hh\:mm")
                </p>

                @if (isExpired)
                {
                    <span class="badge bg-secondary">Event Expired</span>
                }
                else
                {
                    <span class="badge bg-success">Active</span>
                }
            </div>
        </div>

        <!-- Guest Count Control -->
        <div class="card mb-3">
            <div class="card-header card-header-gold py-3">
                <h6 class="mb-0"><i class="bi bi-people me-2"></i>Guest Count</h6>
            </div>
            <div class="card-body">
                <div class="row text-center mb-3">
                    <div class="col-4">
                        <div class="fw-bold fs-4 text-success">@Model.ApprovedCount</div>
                        <small class="text-muted">Approved</small>
                    </div>
                    <div class="col-4">
                        <div class="fw-bold fs-4 text-warning">@Model.PendingCount</div>
                        <small class="text-muted">Pending</small>
                    </div>
                    <div class="col-4">
                        <div class="fw-bold fs-4" style="color:var(--gold)">@Model.MaxGuests</div>
                        <small class="text-muted">Max</small>
                    </div>
                </div>

                <form asp-action="UpdateMaxGuests" method="post">
                    <input type="hidden" name="eventId" value="@Model.EventId" />
                    <label class="form-label small fw-semibold">Adjust Max Guests</label>
                    <div class="input-group">
                        <button type="button" class="btn btn-outline-secondary"
                                onclick="adjustGuests(-1)">−</button>
                        <input type="number" id="maxGuestsInput" name="maxGuests"
                               class="form-control text-center" value="@Model.MaxGuests" min="1" />
                        <button type="button" class="btn btn-outline-secondary"
                                onclick="adjustGuests(1)">+</button>
                    </div>
                    <button type="submit" class="btn btn-gold w-100 mt-2 btn-sm">
                        <i class="bi bi-check2 me-1"></i>Update Count
                    </button>
                </form>
            </div>
        </div>

        <!-- Contact Person -->
        <div class="card mb-3">
            <div class="card-header card-header-gold py-3">
                <h6 class="mb-0"><i class="bi bi-person-badge me-2"></i>Contact Person</h6>
            </div>
            <div class="card-body">
                <p class="mb-1 fw-semibold">@Model.ContactPersonName</p>
                <p class="text-muted small mb-0">@Model.ContactPersonEmail</p>
            </div>
        </div>

        <!-- Registration Link -->
        <div class="card">
            <div class="card-header card-header-gold py-3">
                <h6 class="mb-0"><i class="bi bi-link-45deg me-2"></i>Registration Link</h6>
            </div>
            <div class="card-body">
                <p class="text-muted small mb-2">Share this link so guests can register:</p>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control" id="regLink"
                           value="@Model.RegistrationLink" readonly />
                    <button class="btn btn-outline-secondary" onclick="copyLink()" type="button">
                        <i class="bi bi-clipboard"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Right: Guest List -->
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header card-header-gold py-3 d-flex justify-content-between align-items-center">
                <h6 class="mb-0"><i class="bi bi-list-check me-2"></i>Guest Registrations</h6>
                <span class="badge bg-light text-dark">@Model.Guests.Count total</span>
            </div>
            <div class="card-body p-0">
                @if (!Model.Guests.Any())
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-inbox" style="font-size:2rem"></i>
                        <p class="mt-2">No guests have registered yet.</p>
                    </div>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Guest Name</th>
                                    <th>Registered</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var g in Model.Guests)
                                {
                                    <tr>
                                        <td class="fw-semibold">@g.FullName</td>
                                        <td class="text-muted small">@g.RegisteredAt.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>
                                            @{
                                                var badgeClass = g.Status switch
                                                {
                                                    "Approved" => "status-badge-approved",
                                                    "Rejected" => "status-badge-rejected",
                                                    _ => "status-badge-pending"
                                                };
                                            }
                                            <span class="badge @badgeClass">@g.Status</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function adjustGuests(delta) {
            const input = document.getElementById('maxGuestsInput');
            const current = parseInt(input.value) || 1;
            input.value = Math.max(1, current + delta);
        }

        function copyLink() {
            const input = document.getElementById('regLink');
            input.select();
            navigator.clipboard.writeText(input.value).then(() => {
                const btn = event.target.closest('button');
                btn.innerHTML = '<i class="bi bi-check2"></i>';
                setTimeout(() => btn.innerHTML = '<i class="bi bi-clipboard"></i>', 2000);
            });
        }
    </script>
}
