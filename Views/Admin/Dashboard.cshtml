@model List<EventSummaryViewModel>
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0" style="color:var(--dark)">
            <i class="bi bi-speedometer2 me-2" style="color:var(--gold)"></i>Admin Dashboard
        </h3>
        <small class="text-muted">Manage all hotel buffet events</small>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="CreateStaff" class="btn btn-outline-secondary">
            <i class="bi bi-person-plus me-1"></i>Add Staff
        </a>
        <a asp-action="CreateEvent" class="btn btn-gold">
            <i class="bi bi-plus-circle me-1"></i>New Event
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="card p-5 text-center">
        <i class="bi bi-calendar-x" style="font-size:3rem;color:var(--gold)"></i>
        <h5 class="mt-3">No events yet</h5>
        <p class="text-muted">Create your first buffet event to get started.</p>
        <a asp-action="CreateEvent" class="btn btn-gold mx-auto" style="width:fit-content">
            <i class="bi bi-plus-circle me-1"></i>Create Event
        </a>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var ev in Model)
        {
            var isExpired = ev.EndDate < DateTime.Today;
            var isActive = !isExpired;
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0">@ev.EventName</h6>
                            @if (isExpired)
                            {
                                <span class="badge bg-secondary">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </div>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-building me-1"></i>@ev.HallName
                        </p>
                        <p class="text-muted small mb-2">
                            <i class="bi bi-calendar3 me-1"></i>
                            @ev.StartDate.ToString("dd MMM") – @ev.EndDate.ToString("dd MMM yyyy")
                        </p>
                        <div class="d-flex gap-2 mt-3">
                            <div class="text-center flex-fill p-2 rounded" style="background:#f8f6f0">
                                <div class="fw-bold text-success">@ev.ApprovedCount</div>
                                <small class="text-muted">Approved</small>
                            </div>
                            <div class="text-center flex-fill p-2 rounded" style="background:#f8f6f0">
                                <div class="fw-bold text-warning">@ev.PendingCount</div>
                                <small class="text-muted">Pending</small>
                            </div>
                            <div class="text-center flex-fill p-2 rounded" style="background:#f8f6f0">
                                <div class="fw-bold" style="color:var(--gold)">@ev.MaxGuests</div>
                                <small class="text-muted">Max</small>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0">
                        <a asp-action="EventDetail" asp-route-id="@ev.EventId"
                           class="btn btn-sm btn-gold w-100">
                            <i class="bi bi-eye me-1"></i>View & Manage
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
