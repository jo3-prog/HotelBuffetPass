@model CreateEventViewModel
@{
    ViewData["Title"] = "Create New Event";
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header card-header-gold py-3">
                <h5 class="mb-0"><i class="bi bi-calendar-plus me-2"></i>Create New Buffet Event</h5>
            </div>
            <div class="card-body p-4">
                <form asp-action="CreateEvent" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <h6 class="fw-bold text-muted mb-3 border-bottom pb-2">Event Details</h6>

                    <div class="row g-3 mb-3">
                        <div class="col-md-8">
                            <label asp-for="EventName" class="form-label fw-semibold"></label>
                            <input asp-for="EventName" class="form-control" placeholder="e.g. ACME Corp Annual Conference" />
                            <span asp-validation-for="EventName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="HallName" class="form-label fw-semibold"></label>
                            <input asp-for="HallName" class="form-control" placeholder="e.g. Grand Ballroom" />
                            <span asp-validation-for="HallName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="StartDate" class="form-label fw-semibold"></label>
                            <input asp-for="StartDate" class="form-control" type="date" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="EndDate" class="form-label fw-semibold"></label>
                            <input asp-for="EndDate" class="form-control" type="date" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <h6 class="fw-bold text-muted mb-3 border-bottom pb-2 mt-4">Buffet Hours</h6>
                    <p class="text-muted small">QR codes will only be scannable within these hours each day.</p>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label asp-for="BuffetStartTime" class="form-label fw-semibold"></label>
                            <input asp-for="BuffetStartTime" class="form-control" type="time" />
                            <span asp-validation-for="BuffetStartTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="BuffetEndTime" class="form-label fw-semibold"></label>
                            <input asp-for="BuffetEndTime" class="form-control" type="time" />
                            <span asp-validation-for="BuffetEndTime" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="MaxGuests" class="form-label fw-semibold"></label>
                            <input asp-for="MaxGuests" class="form-control" type="number" min="1" placeholder="e.g. 50" />
                            <span asp-validation-for="MaxGuests" class="text-danger small"></span>
                        </div>
                    </div>

                    <h6 class="fw-bold text-muted mb-3 border-bottom pb-2 mt-4">Contact Person</h6>
                    <p class="text-muted small">
                        This person will receive a login and the registration link to share with guests.
                        If they already have an account, their existing account will be used.
                    </p>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="ContactPersonName" class="form-label fw-semibold"></label>
                            <input asp-for="ContactPersonName" class="form-control" placeholder="Full name" />
                            <span asp-validation-for="ContactPersonName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ContactPersonEmail" class="form-label fw-semibold"></label>
                            <input asp-for="ContactPersonEmail" class="form-control" type="email" placeholder="contact@company.com" />
                            <span asp-validation-for="ContactPersonEmail" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-gold px-4">
                            <i class="bi bi-send me-2"></i>Create Event & Notify Contact
                        </button>
                        <a asp-action="Dashboard" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
