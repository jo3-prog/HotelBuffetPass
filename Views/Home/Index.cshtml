@{
    ViewData["Title"] = "Welcome";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-7 text-center">
        <div class="card p-5">
            <div class="mb-3" style="font-size: 3.5rem;">⭐</div>
            <h2 class="fw-bold" style="color: var(--dark);">Hotel Buffet Pass System</h2>
            <p class="text-muted mt-2 mb-4">
                A seamless digital solution for event buffet access — replacing paper vouchers with
                verified QR passes.
            </p>
            <div class="d-flex gap-3 justify-content-center flex-wrap">
                <a asp-controller="Account" asp-action="Login" class="btn btn-gold px-4 py-2">
                    <i class="bi bi-shield-lock me-2"></i>Staff Login
                </a>
                <a asp-controller="Guest" asp-action="Lookup" class="btn btn-outline-secondary px-4 py-2">
                    <i class="bi bi-qr-code me-2"></i>Find My Buffet Pass
                </a>
            </div>
        </div>
    </div>
</div>
