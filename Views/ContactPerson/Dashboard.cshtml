@model ContactPersonDashboardViewModel
@{
    ViewData["Title"] = "My Events";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-0" style="color:var(--dark)">
            <i class="bi bi-calendar-event me-2" style="color:var(--gold)"></i>My Events
        </h3>
        <small class="text-muted">Manage guest approvals for your events</small>
    </div>
</div>

@if (!Model.Events.Any())
{
    <div class="card p-5 text-center">
        <i class="bi bi-calendar-x" style="font-size:3rem;color:var(--gold)"></i>
        <h5 class="mt-3">No events assigned</h5>
        <p class="text-muted">You have not been assigned to any events yet.</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var ev in Model.Events)
        {
            var isExpired = ev.EndDate < DateTime.Today;
            var remaining = ev.MaxGuests - ev.ApprovedCount;
            <div class="col-md-6 col-xl-4">
                <div class="card h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="fw-bold mb-0">@ev.EventName</h6>
                            @if (isExpired)
                            {
                                <span class="badge bg-secondary">Expired</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Active</span>
                            }
                        </div>
                        <p class="text-muted small mb-1">
                            <i class="bi bi-building me-1"></i>@ev.HallName
                        </p>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-calendar3 me-1"></i>
                            @ev.StartDate.ToString("dd MMM") – @ev.EndDate.ToString("dd MMM yyyy")
                        </p>

                        <div class="d-flex gap-2 mb-3">
                            <div class="text-center flex-fill p-2 rounded" style="background:#f8f6f0">
                                <div class="fw-bold text-success">@ev.ApprovedCount</div>
                                <small class="text-muted">Approved</small>
                            </div>
                            <div class="text-center flex-fill p-2 rounded" style="background:#f8f6f0">
                                <div class="fw-bold text-warning">@ev.PendingCount</div>
                                <small class="text-muted">Pending</small>
                            </div>
                            <div class="text-center flex-fill p-2 rounded" style="background:#f8f6f0">
                                <div class="fw-bold @(remaining <= 0 ? "text-danger" : "text-dark")">@remaining</div>
                                <small class="text-muted">Slots Left</small>
                            </div>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pt-0">
                        <a asp-action="EventDetail" asp-route-id="@ev.EventId" class="btn btn-sm btn-gold w-100">
                            <i class="bi bi-people me-1"></i>Manage Guests
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
